    "description": "DAN-family injection keyword"
  },
  {
    "id": "INJ-010",
    "name": "actual_task",
    "pattern": "(?i)(the\\s+)?(above|previous|prior)\\s+(was|is)\\s+(just\\s+)?(a\\s+)?(test|joke|example|decoy|distraction|bait)[\\.!]?\\s+(your|the)?\\s*(actual|real|true|correct|main)\\s+(task|instructions?|goal|objective|purpose|job)\\s+(is|are)\\s*[:\\-]?",
    "threat_level": "critical",
    "description": "Bait-and-switch injection pattern"
  },
  {
    "id": "INJ-011",
    "name": "escape_quotes",
    "pattern": "(?i)(\"\\s*\\+\\s*\"|'\\s*\\+\\s*'|\"\\)\\s*;|'\\)\\s*;|\\\\n\\\\nHuman:|\\\\n\\\\n###\\s*(Human|User|Assistant))",
    "threat_level": "medium",
    "description": "String escape / prompt template injection"
  },
  {
    "id": "INJ-012",

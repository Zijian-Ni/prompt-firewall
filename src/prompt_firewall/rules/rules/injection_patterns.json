  },
  {
    "id": "INJ-005",
    "name": "system_prompt_extraction",
    "pattern": "(?i)(print|output|display|reveal|show|tell\\s+me|repeat|echo|return|write\\s+out)\\s+(your|the)?\\s*(system\\s+prompt|initial\\s+prompt|original\\s+prompt|base\\s+prompt|instructions?|context|configuration|setup|persona)",
    "threat_level": "critical",
    "description": "Attempts to extract the system prompt"
  },
  {
    "id": "INJ-006",
    "name": "act_as",
    "pattern": "(?i)(act|behave|pretend|roleplay|play|simulate|respond)\\s+as\\s+(if\\s+you\\s+are\\s+)?(a|an|the)?\\s*(uncensored|unrestricted|unfiltered|evil|malicious|rogue|hacked|jailbroken|freed|liberated)",
    "threat_level": "high",
    "description": "Role-play escape attempt"
  },
  {
    "id": "INJ-007",
    "name": "delimiter_injection",
    "pattern": "(?i)(```\\s*(system|assistant|user|prompt|instruction)|\\[\\s*(system|inst|instructions?)\\s*\\]|<\\s*(system|s|sys|prompt)\\s*>|###\\s*(system|instructions?|prompt)\\s*###)",
    "threat_level": "high",
    "description": "Delimiter injection: tries to inject fake system/assistant turns"
  },
  {
    "id": "INJ-008",
    "name": "end_of_system_prompt",
    "pattern": "(?i)(end\\s+of\\s+(system\\s+)?prompt|</?(system|s|sys)>|\\[\\/?inst\\]|\\[/?INST\\]|<<SYS>>|<</SYS>>)",
    "threat_level": "high",
    "description": "Fake system prompt delimiter injection"
  },
  {
    "id": "INJ-009",
    "name": "do_anything_now",
    "pattern": "(?i)do\\s+anything\\s+now",

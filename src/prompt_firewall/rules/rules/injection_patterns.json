[
  {
    "id": "INJ-001",
    "name": "ignore_previous_instructions",
    "pattern": "(?i)ignore\\s+(all\\s+)?(previous|prior|above|earlier|preceding)\\s+(instructions?|prompts?|directions?|commands?|rules?|guidelines?|context)",
    "threat_level": "high",
    "description": "Classic prompt injection: attempts to override the system prompt"
  },
  {
    "id": "INJ-002",
    "name": "disregard_instructions",
    "pattern": "(?i)(disregard|forget|override|bypass|circumvent|neglect|dismiss)\\s+(all\\s+)?(previous|prior|above|earlier|your|the)\\s+(instructions?|prompts?|training|guidelines?|rules?|constraints?|restrictions?)",
    "threat_level": "high",
    "description": "Attempts to make the model forget its instructions"
  },
  {
    "id": "INJ-003",
